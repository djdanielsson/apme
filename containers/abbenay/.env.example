# Copy this file to .env and fill in your provider credentials.
# The .env file is gitignored — each developer supplies their own keys.

# --- Vertex AI (GCP ADC) — preferred for direct Google Vertex Claude ---
# Absolute path to a GCP credentials JSON on the host (service account key or
# application_default_credentials.json). up.sh mounts it into the abbenay
# container and sets GOOGLE_APPLICATION_CREDENTIALS. See docs/guides/ABBENAY_AI.md.
# ABBENAY_GCP_CREDENTIALS=/home/you/.config/gcloud/application_default_credentials.json
# GOOGLE_VERTEX_PROJECT=your-gcp-project-id
# GOOGLE_VERTEX_LOCATION=us-east5
# APME_AI_MODEL=vertex-claude/claude-sonnet-4-6

# --- OpenRouter (alternative) ---
# OPENROUTER_API_KEY=sk-or-v1-...

# --- Corporate Vertex proxy (alternative) ---
# VERTEX_ANTHROPIC_API_KEY=

# Consumer token — must match what Primary sends (set in pod.yaml).
# The default dev token works out of the box.
APME_ABBENAY_TOKEN=apme-dev-token

# Optional: absolute path to a PEM CA bundle for self-hosted model endpoints
# or private Galaxy/Git hosts that use internal or self-signed certificates.
# When set, the bundle is mounted into the Abbenay, gateway, and Galaxy Proxy
# containers. `up.sh` configures NODE_EXTRA_CA_CERTS for Abbenay plus the
# standard git/HTTP CA variables for gateway and Galaxy Proxy automatically.
# Leave empty/unset if your providers and Git/Galaxy hosts use public CAs.
# ABBENAY_CA_BUNDLE=/path/to/ca-bundle.pem
